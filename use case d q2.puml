@startuml
left to right direction
skinparam packageStyle rectangle

actor Waiter
actor Cashier

rectangle "Restaurant Ordering System" {
  usecase "Add Order" as UC1
  usecase "Cancel Order" as UC2
  usecase "Schedule Order" as UC3
  usecase "View Orders" as UC4
  usecase "Process Payment" as UC5
  usecase "Print Receipt" as UC6
}

Waiter --> UC1
Waiter --> UC2
Waiter --> UC3
Waiter --> UC4

Cashier --> UC5
Cashier --> UC6

UC6 .> UC5 : <<include>>
@enduml