@startuml
class User {
  - userId: String
  - name: String
  - email: String
  - password: String
  - phoneNumber: String
  + register()
  + login()
  + updateProfile()
}

class Vendor {
  - businessName: String
  - address: String
  - cuisineType: String
  + postFoodItem()
  + editFoodItem()
  + viewOrders()
  + markOrderReady()
}

class Consumer {
  - location: String
  - preferences: String
  + browseFoodItems()
  + searchFood()
  + placeOrder()
  + rateVendor()
}

class FoodItem {
  - itemId: String
  - name: String
  - description: String
  - originalPrice: Float
  - discountedPrice: Float
  - quantity: Integer
  - photo: String
  - pickupTime: DateTime
  + create()
  + update()
  + delete()
}

class Order {
  - orderId: String
  - orderDate: DateTime
  - totalPrice: Float
  - status: String
  - pickupTime: DateTime
  + createOrder()
  + updateStatus()
  + cancelOrder()
}

class Review {
  - reviewId: String
  - rating: Integer
  - comment: String
  - reviewDate: DateTime
  + submitReview()
  + editReview()
}

User <|-- Vendor
User <|-- Consumer

Vendor "1" -- "*" FoodItem : posts
Consumer "1" -- "*" Order : places
Vendor "1" -- "*" Order : receives
Order "*" -- "1" FoodItem : contains
Consumer "1" -- "*" Review : writes
Vendor "1" -- "*" Review : receives

@enduml