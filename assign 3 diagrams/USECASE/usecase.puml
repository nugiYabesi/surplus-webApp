@startuml
left to right direction
skinparam packageStyle rectangle

actor Vendor
actor Consumer
actor "Payment Gateway" as PG

rectangle "Food Waste Reduction App" {
  usecase "Register" as UC1
  usecase "Login" as UC2
  usecase "Post Food Item" as UC3
  usecase "Edit Food Item" as UC4
  usecase "Browse Food Items" as UC5
  usecase "Search Food" as UC6
  usecase "Place Order" as UC7
  usecase "Make Payment" as UC8
  usecase "Rate & Review" as UC9
  usecase "View Order History" as UC10
}

Vendor --> UC1
Vendor --> UC2
Vendor --> UC3
Vendor --> UC4
Vendor --> UC10

Consumer --> UC1
Consumer --> UC2
Consumer --> UC5
Consumer --> UC6
Consumer --> UC7
Consumer --> UC9
Consumer --> UC10

UC7 ..> UC8 : <<include>>
UC8 --> PG

@enduml